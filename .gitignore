# competition data (never redistribute)
train/
train_sample/
public_test/
private_test/
test/
*.csv
!sample_submission_schema.csv

# external datasets (fetched by scripts; cite, don't redistribute)
external/

# heavy artifacts (features, checkpoints; packaged into the Docker image instead)
artifacts/*.npz
artifacts/*.log
artifacts/fusion_cache/
artifacts/smoke_data/
docker/hf_cache/
# weights/ IS tracked (via Git LFS, see .gitattributes) — it mirrors the
# frozen inference weights also hosted on Hugging Face.
experiments/*/adapters.pt
experiments/*/model.pt
experiments/*/*.tmp

# env / caches
__pycache__/
*.pyc
env/
.claude/
